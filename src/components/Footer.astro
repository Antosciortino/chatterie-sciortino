---
import PawPrint from './PawPrint.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <div class="footer-brand">
        <PawPrint size={20} rotate={-15} class="brand-paw" />
        Chatterie Sciortino
      </div>
      <p class="muted">Élevage familial de Ragdolls. Gonfaron, Var (83).</p>
    </div>
    <nav aria-label="Liens secondaires">
      <ul>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/mentions-legales/">Mentions légales</a></li>
      </ul>
    </nav>
  </div>
  <div class="container copyright">© {year} Chatterie Sciortino</div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding: 3rem 0 1.5rem;
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-brand :global(.brand-paw) { color: var(--accent); opacity: 0.7; }
  .muted { color: var(--text-muted); margin: 0.25rem 0 0; }
  ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  ul a { color: var(--text); text-decoration: none; }
  ul a:hover { color: var(--accent-dark); }
  .copyright {
    font-size: 0.85rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }
</style>
