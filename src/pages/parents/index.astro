---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PawPrint from '../../components/PawPrint.astro';

const chats = (await getCollection('chats')).sort((a, b) => a.data.ordre - b.data.ordre);
const males = chats.filter(c => c.data.sexe === 'mâle');
const femelles = chats.filter(c => c.data.sexe === 'femelle');
---

<BaseLayout titre="Nos chats">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Les reproducteurs</p>
      <h1>Nos chats</h1>
      <p class="lede">
        Tous nos chats vivent à la maison, en famille. Tests HCM et PKD,
        suivi vétérinaire régulier.
      </p>
      <div class="paw-row" aria-hidden="true">
        <PawPrint size={14} rotate={-20} />
        <PawPrint size={18} rotate={10} />
        <PawPrint size={14} rotate={-5} />
      </div>

      {femelles.length > 0 && (
        <>
          <h2 style="margin-top: 3rem;">Femelles</h2>
          <div class="grid">
            {femelles.map(chat => (
              <a href={`/parents/${chat.id}/`} class="card">
                <div class="card-img">
                  <Image src={chat.data.photo} alt={chat.data.nom} width={500} height={375} />
                </div>
                <div class="card-body">
                  <h3>{chat.data.nom}</h3>
                  <p class="muted">{chat.data.couleur}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      {males.length > 0 && (
        <>
          <h2 style="margin-top: 3rem;">Mâles</h2>
          <div class="grid">
            {males.map(chat => (
              <a href={`/parents/${chat.id}/`} class="card">
                <div class="card-img">
                  <Image src={chat.data.photo} alt={chat.data.nom} width={500} height={375} />
                </div>
                <div class="card-body">
                  <h3>{chat.data.nom}</h3>
                  <p class="muted">{chat.data.couleur}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      {chats.length === 0 && (
        <p>Les fiches arrivent bientôt.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .lede { font-size: 1.1rem; color: var(--text-muted); max-width: 60ch; }
  .muted { color: var(--text-muted); margin: 0.25rem 0 0; }
  .paw-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1.5rem;
    color: var(--accent);
    opacity: 0.45;
  }
</style>
