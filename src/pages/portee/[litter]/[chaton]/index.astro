---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PawPrint from '../../../../components/PawPrint.astro';
import { chatonSlug } from '../../../../lib/slug';

export async function getStaticPaths() {
  const portees = await getCollection('portees');
  return portees.flatMap(portee =>
    portee.data.chatons.map(chaton => ({
      params: { litter: portee.id, chaton: chatonSlug(chaton.nom) },
      props: { portee, chaton },
    }))
  );
}

const { portee, chaton } = Astro.props;
const pere = await getEntry(portee.data.pere);
const mere = await getEntry(portee.data.mere);
const naissance = portee.data.date_naissance.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const photos = chaton.photos;
---

<BaseLayout titre={chaton.nom} description={`${chaton.nom}, chaton ${chaton.sexe} ${chaton.couleur} de la Chatterie Sciortino.`}>
  <article class="section">
    <div class="container">
      <p class="eyebrow">Chaton · {portee.data.titre}</p>
      <h1>{chaton.nom}</h1>

      <div class="layout">
        <div class="photo-stack">
          <div class="photo">
            {photos.length === 0 && <div class="no-photo" aria-label="Photos à venir"></div>}
            {photos.map((p, i) => (
              <Image src={p} alt={chaton.nom} width={900} height={675} class:list={['main-photo', { active: i === 0 }]} />
            ))}
          </div>
          {photos.length > 1 && (
            <div class="thumbs" role="tablist" aria-label="Plus de photos">
              {photos.map((p, i) => (
                <button type="button" class:list={['thumb', { active: i === 0 }]} data-index={i} aria-label={`Photo ${i + 1}`}>
                  <Image src={p} alt="" width={140} height={105} />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="meta">
          <p><span class={`badge ${chaton.statut}`}>{chaton.statut}</span></p>
          <dl class="facts">
            <dt>Sexe</dt><dd>{chaton.sexe === 'mâle' ? 'Mâle' : 'Femelle'}</dd>
            <dt>Couleur</dt><dd>{chaton.couleur}</dd>
            <dt>Né{chaton.sexe === 'femelle' ? 'e' : ''} le</dt><dd>{naissance}</dd>
            <dt>Mère</dt><dd><a href={`/parents/${mere.id}/`}>{mere.data.nom}</a></dd>
            <dt>Père</dt><dd><a href={`/parents/${pere.id}/`}>{pere.data.nom}</a></dd>
          </dl>
        </div>
      </div>

      {chaton.notes && (
        <div class="notes-block">
          <p>{chaton.notes}</p>
        </div>
      )}

      <div class="legal-info">
        <strong>Informations légales :</strong><br/>
        Race : Ragdoll · LOOF · Numéro de portée : {portee.data.numero_portee_loof} · ICAD mère : {portee.data.icad_mere}
      </div>

      <p class="back-link">
        <a href="/portee/">← Retour à la portée</a>
        <PawPrint size={16} rotate={-15} class="back-paw" />
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
    align-items: start;
    margin: 2rem 0;
  }
  .photo-stack { display: flex; flex-direction: column; gap: 0.6rem; }
  .photo {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow);
    background: var(--bg-alt);
  }
  .no-photo {
    position: absolute;
    inset: 0;
    background: var(--bg-alt);
  }
  .main-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .main-photo.active { opacity: 1; }
  .thumbs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .thumb {
    padding: 0;
    border: 2px solid transparent;
    border-radius: 8px;
    background: none;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s, transform 0.15s;
    width: 70px;
    height: 52px;
    flex-shrink: 0;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .thumb.active { border-color: var(--accent); }
  .thumb:hover { transform: translateY(-1px); }

  .meta { display: flex; flex-direction: column; gap: 1rem; }
  .facts {
    background: var(--bg-alt);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1.5rem;
    row-gap: 0.75rem;
  }
  .facts dt {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    align-self: center;
  }
  .facts dd { margin: 0; align-self: center; }
  .notes-block {
    max-width: 60ch;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-muted);
  }
  .legal-info { max-width: 60ch; margin: 1.5rem 0; }
  .back-link {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .back-link :global(.back-paw) { color: var(--accent); opacity: 0.55; }

  @media (max-width: 720px) {
    .layout { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.photo-stack').forEach(stack => {
    const mains = stack.querySelectorAll<HTMLElement>('.main-photo');
    const thumbs = stack.querySelectorAll<HTMLButtonElement>('.thumb');
    thumbs.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.dataset.index);
        mains.forEach((m, i) => m.classList.toggle('active', i === idx));
        thumbs.forEach((t, i) => t.classList.toggle('active', i === idx));
      });
    });
  });
</script>
